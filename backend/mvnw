#!/usr/bin/env sh

set -eu

BASE_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
WRAPPER_DIR="$BASE_DIR/.mvn/wrapper"
MAVEN_VERSION="3.9.9"
MAVEN_FOLDER="apache-maven-$MAVEN_VERSION"
MAVEN_HOME="$WRAPPER_DIR/$MAVEN_FOLDER"
MAVEN_TGZ="$WRAPPER_DIR/$MAVEN_FOLDER-bin.tar.gz"
MVN_CMD="$MAVEN_HOME/bin/mvn"
DIST_URL="https://repo.maven.apache.org/maven2/org/apache/maven/apache-maven/$MAVEN_VERSION/$MAVEN_FOLDER-bin.tar.gz"

if [ ! -x "$MVN_CMD" ]; then
  echo "Maven $MAVEN_VERSION not found in project wrapper cache."
  echo "Downloading Maven wrapper distribution..."
  mkdir -p "$WRAPPER_DIR"
  curl -fsSL "$DIST_URL" -o "$MAVEN_TGZ"
  tar -xzf "$MAVEN_TGZ" -C "$WRAPPER_DIR"
fi

exec "$MVN_CMD" "$@"
